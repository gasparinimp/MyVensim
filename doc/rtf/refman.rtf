59         {\cf19 for} ({\cf18 size_t} i = 0; i < flows.size(); ++i) \{\par
60             results.push_back(flows[i]->execute());\par
61         \}\par
62         \par
63         {\cf20 //Pego os sistemas de origem e destino dos fluxos}\par
64         {\cf19 for} ({\cf18 size_t} i = 0; i < flows.size(); ++i) \{\par
65             System* origem = flows[i]->getSource();\par
66             System* destino = flows[i]->getTarget();\par
67             {\cf20 //Se n\'E3o forem nulos, atualizo os valores ao mesmo tempo para n\'E3o ter inconsist\'EAncia}\par
68             {\cf19 if} (origem != {\cf17 nullptr}) \{\par
69                 origem->setValue(origem->getValue() - results[i]);\par
70             \}\par
71             {\cf19 if} (destino != {\cf17 nullptr}) \{\par
72                 destino->setValue(destino->getValue() + results[i]);\par
73             \}\par
74         \}\par
75     \}\par
76 \}\par
}
}
