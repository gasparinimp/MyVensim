54     {\cf18 double} execute(){\cf17  const override }\{\par
55         {\cf19 if} (getSource() != {\cf17 nullptr}) \{\par
56             {\cf19 return} 0.01 * getSource()->getValue(); {\cf20 // Equa\'E7\'E3o base do fluxo complexo}\par
57         \}\par
58         {\cf19 return} 0.0;\par
59     \}\par
60 \};\par
61 \par
62 {\cf21 #endif}\par
}
