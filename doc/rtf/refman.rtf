19     {\cf18 double} execute(){\cf17  const override }\{\par
20         {\cf20 //Pego a origem se for diferente de nulo}\par
21         {\cf19 if} (getSource() != {\cf17 nullptr}) \{\par
22             {\cf20 //Pego o valor atual e multiplico do 0.01}\par
23             {\cf19 return} 0.01 * getSource()->getValue();\par
24         \}\par
25         {\cf19 return} 0.0;\par
26     \}\par
27 \};\par
28 \par
29 {\cf20 //Heran\'E7a, logistica herdando de flow}\par
30 {\cf17 class }LogisticaFlow : {\cf17 public} Flow \{\par
31 {\cf17 public}:\par
32     {\cf20 //Herdando os construtores de forma canonica do flow}\par
33     {\cf17 using }Flow::Flow;\par
34 \par
35     {\cf20 //Sobreescrita do metodo executa}\par
36     {\cf18 double} execute(){\cf17  const override }\{\par
37         {\cf20 //Pego a origem se ela nao for nula}\par
38         {\cf19 if} (getTarget() != {\cf17 nullptr}) \{\par
39             {\cf20 //Pego o valor atual}\par
40             {\cf18 double} p2 = getTarget()->getValue();\par
41             {\cf20 //Fa\'E7o as contas pedidas pelo cliente}\par
42             {\cf19 return} 0.01 * p2 * (1.0 - (p2 / 70.0));\par
43         \}\par
44         {\cf19 return} 0.0;\par
45     \}\par
46 \};\par
47 \par
